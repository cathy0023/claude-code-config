# ai-sop-api 开发环境变量模板
# 复制此文件为 .env 并填入实际凭据
# .env 文件不应提交到版本控制

# PostgreSQL
POSTGRES__HOST=127.0.0.1
POSTGRES__PORT=6432
POSTGRES__USER=postgres
POSTGRES__PASSWORD=your_postgres_password_here
POSTGRES__DATABASE=megaview

# Valkey/Redis
VALKEY__HOST=127.0.0.1
VALKEY__PORT=6379
VALKEY__PASSWORD=your_valkey_password_here

# 阿里云 DashScope (通义千问等)
DASHSCOPE__API_KEY=your_dashscope_api_key_here

# DashVector
DASHVECTOR__API_KEY=your_dashvector_api_key_here
DASHVECTOR__ENDPOINT=vrs-cn-xxxxx.dashvector.cn-beijing.aliyuncs.com

# 豆包 ARK
DOUBAO__ARK_API_KEY=your_doubao_ark_api_key_here

# 阿里云 OSS
ALIYUN_OSS__ACCESS_KEY_ID=your_aliyun_access_key_id
ALIYUN_OSS__ACCESS_KEY_SECRET=your_aliyun_access_key_secret
ALIYUN_OSS__BUCKET_NAME=sale-test
ALIYUN_OSS__ENDPOINT=https://oss-cn-zhangjiakou.aliyuncs.com

# NSQ
NSQ__LOOKUPD_ADDR=127.0.0.1:4161

# JWT
JWT__SOP_SECRET_KEY=your_jwt_secret_key_here

# Consul (本地开发设为 false)
USE_CONSUL=false

# 测试用 JWT Token (可选)
# CI_TEST_JWT=your_test_jwt_token_here